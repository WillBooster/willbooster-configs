{
  "name": "@willbooster/babel-configs",
  "version": "0.0.0-semantically-released",
  "description": "Babel configs for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/babel-configs"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "files": [
    "babel.*.cjs"
  ],
  "scripts": {
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true",
    "cleanup": "yarn format",
    "format": "sort-package-json",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "devDependencies": {
    "@types/babel__core": "7.20.5",
    "@willbooster/wb": "13.12.9",
    "core-js": "3.49.0",
    "sort-package-json": "3.6.1"
  },
  "peerDependencies": {
    "@babel/core": ">=7",
    "@babel/plugin-proposal-class-properties": ">=7",
    "@babel/plugin-proposal-numeric-separator": ">=7",
    "@babel/preset-env": ">=7",
    "@babel/preset-react": ">=7",
    "@babel/preset-typescript": ">=7",
    "babel-plugin-transform-remove-console": ">=6",
    "core-js": ">=3"
  },
  "peerDependenciesMeta": {
    "@babel/preset-react": {
      "optional": true
    },
    "core-js": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
