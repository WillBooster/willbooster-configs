{
  "name": "@willbooster/eslint-config-js",
  "version": "0.0.0-semantically-released",
  "description": "ESLint flat config for JavaScript projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/eslint-config-js"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "main": "eslint.config.js",
  "types": "eslint.config.d.ts",
  "files": [
    "eslint.config.d.ts",
    "eslint.config.js"
  ],
  "scripts": {
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "test": "bun wb test",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@willbooster/wb": "15.3.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2000",
    "sort-package-json": "4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
