{
  "name": "@willbooster/configs",
  "version": "0.0.0-semantically-released",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "prepare": "lefthook install || true",
    "release": "bun run multi-semantic-release --debug",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "prettier": "@willbooster/prettier-config",
  "devDependencies": {
    "@anolilab/multi-semantic-release": "4.4.4",
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@willbooster/wb": "15.0.4",
    "conventional-changelog-conventionalcommits": "9.3.1",
    "lefthook": "2.1.10",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.25.0",
    "prettier": "3.8.3",
    "prettier-plugin-java": "2.9.7",
    "semantic-release": "25.0.3",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
