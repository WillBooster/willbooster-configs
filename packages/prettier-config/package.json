{
  "name": "@willbooster/prettier-config",
  "version": "0.0.0-semantically-released",
  "description": "Prettier config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/prettier-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "main": ".prettierrc.json",
  "files": [
    ".prettierrc.json"
  ],
  "scripts": {
    "cleanup": "yarn format",
    "format": "sort-package-json && yarn prettify",
    "prettify": "prettier --cache --color --no-error-on-unmatched-pattern --write \"**/{.*/,}*.{java}\" \"!**/test{-,/}fixtures/**\" || true",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "devDependencies": {
    "@willbooster/wb": "13.12.13",
    "prettier": "3.8.3",
    "prettier-plugin-java": "2.8.1",
    "sort-package-json": "3.6.1"
  },
  "peerDependencies": {
    "prettier": ">=3",
    "prettier-plugin-java": ">=2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
