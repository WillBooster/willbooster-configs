{
  "name": "@willbooster/oxlint-config",
  "version": "0.0.0-semantically-released",
  "description": "Oxlint config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/oxlint-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./config.d.ts",
      "default": "./config.mjs"
    }
  },
  "main": "config.mjs",
  "types": "config.d.ts",
  "files": [
    "config.d.ts",
    "config.mjs",
    "oxlint.config.ts",
    "config.d.mts"
  ],
  "scripts": {
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "test": "bun wb test",
    "typecheck": "bun wb typecheck",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "devDependencies": {
    "@tsconfig/bun": "1.0.10",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/bun": "1.3.14",
    "@types/node": "25.9.1",
    "@willbooster/wb": "15.3.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "7.0.2000",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2"
  },
  "peerDependencies": {
    "oxlint": ">=1.60.0",
    "oxlint-tsgolint": ">=0.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
