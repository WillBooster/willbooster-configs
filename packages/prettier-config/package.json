{
  "name": "@willbooster/prettier-config",
  "version": "0.0.0-semantically-released",
  "description": "Prettier config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/prettier-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "main": ".prettierrc.json",
  "files": [
    ".prettierrc.json"
  ],
  "scripts": {
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "test": "bun wb test",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "devDependencies": {
    "@willbooster/wb": "15.3.0",
    "prettier": "3.8.3",
    "prettier-plugin-java": "2.9.7",
    "sort-package-json": "4.0.0"
  },
  "peerDependencies": {
    "prettier": ">=3",
    "prettier-plugin-java": ">=2.6"
  },
  "publishConfig": {
    "access": "public"
  }
}
