{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  description: 'Default preset for use with WillBooster and WillBoosterLab repos',
  extends: [
    'config:recommended',
    ':automergeDigest',
    ':automergeLinters',
    ':automergeMinor',
    ':automergePr',
    ':automergeTesters',
    ':automergeTypes',
    ':prImmediately',
    ':rebaseStalePrs',
    ':semanticCommits',
    'group:linters',
    'group:nextjsMonorepo',
    'group:test',
    'group:definitelyTyped',
    'group:prismaMonorepo',
    'group:recommended',
    'group:semantic-releaseMonorepo',
    'docker:enableMajor',
    'docker:pinDigests',
  ],
  dependencyDashboardAutoclose: true,
  packageRules: [
    {
      matchDatasources: ['npm'],
      minimumReleaseAge: '5 days',
    },
    {
      groupName: 'all patch dependencies',
      groupSlug: 'all-patch',
      matchPackageNames: [
        '*',
        // group:recommended -> group:nodeJs
        '!/(?:^|/)node$/',
        // group:nextjsMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupnextjsmonorepo
        // source: https://github.com/vercel/next.js
        '!next',
        '!@next/bundle-analyzer',
        '!@next/codemod',
        '!@next/env',
        '!@next/eslint-plugin-internal',
        '!@next/eslint-plugin-next',
        '!@next/font',
        '!@next/mdx',
        '!@next/playwright',
        '!@next/plugin-storybook',
        '!@next/polyfill-module',
        '!@next/polyfill-nomodule',
        '!@next/react-refresh-utils',
        '!@next/routing',
        '!@next/swc',
        '!@next/third-parties',
        '!create-next-app',
        '!eslint-config-next',
        '!next-rspack',
        '!styled-jsx',
        // group:linters
        '!*/eslint-plugin',
        '!@babel/eslint-parser',
        '!/^@eslint\\//',
        '!/^@eslint-community\\//',
        '!/^@stylistic\\/eslint-plugin/',
        '!@types/eslint',
        '!/^@types\\/eslint__/',
        '!/^@typescript-eslint\\//',
        '!babel-eslint',
        '!/^eslint/',
        '!globals',
        '!eslint-import-resolver-typescript',
        '!typescript-eslint',
        '!oxlint',
        '!eslint-plugin-oxlint',
        // group:definitelyTyped
        '!/^@types\\//',
        // group:recommended -> group:react
        '!/^react/',
        '!/^@types\\/react/',
        '!react-dom',
        '!@types/react-dom',
        '!@types/react-is',
        // group:recommended -> group:remark
        '!remark',
        '!remark-**',
        // group:semantic-releaseMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupsemantic-releasemonorepo
        // source: https://github.com/semantic-release/**
        '!@semantic-release/apm',
        '!@semantic-release/apm-config',
        '!@semantic-release/changelog',
        '!@semantic-release/commit-analyzer',
        '!@semantic-release/condition-codeship',
        '!@semantic-release/condition-nsp',
        '!@semantic-release/condition-run-script',
        '!@semantic-release/condition-travis',
        '!@semantic-release/error',
        '!@semantic-release/exec',
        '!@semantic-release/git',
        '!@semantic-release/github',
        '!@semantic-release/gitlab',
        '!@semantic-release/gitlab-config',
        '!@semantic-release/last-release-git-tag',
        '!@semantic-release/last-release-npm',
        '!@semantic-release/npm',
        '!@semantic-release/release-notes-generator',
        '!@semantic-release/wordpress',
        '!cracks',
        '!env-ci',
        '!issue-parser',
        '!npm-registry-docker',
        '!semantic-release',
        '!semantic-release-cli',
        '!travis-deploy-once',
        '!prettier',
        '!remark-lint',
        '!standard',
        '!codelyzer',
        '!/\\btslint\\b/',
        // group:test and group:recommended -> jestPlusTypes / jestPlusTSJest
        '!@types/chai',
        '!@types/ember-mocha',
        '!@types/ember-qunit',
        '!@types/enzyme',
        '!@types/istanbul',
        '!@types/jest',
        '!@types/mocha',
        '!@types/mock-fs',
        '!@types/proxyquire',
        '!@types/sinon',
        '!@types/supertest',
        '!coveralls',
        '!ember-exam',
        '!ember-mocha',
        '!ember-qunit',
        '!enzyme',
        '!istanbul',
        '!mock-fs',
        '!nock',
        '!nyc',
        '!proxyquire',
        '!supertest',
        '!ts-auto-mock',
        '!ts-jest',
        '!vitest',
        '!/^@jest\\//',
        '!/^@testing-library\\//',
        '!/^@types\\/testing-library__/',
        '!/^@vitest\\//',
        '!/^chai/',
        '!/^jest/',
        '!/^mocha/',
        '!/^qunit/',
        '!/^should/',
        '!/^sinon/',
        // group:prismaMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupprismamonorepo
        // source: https://github.com/prisma/prisma
        '!@prisma/adapter-better-sqlite3',
        '!@prisma/adapter-d1',
        '!@prisma/adapter-libsql',
        '!@prisma/adapter-mariadb',
        '!@prisma/adapter-mssql',
        '!@prisma/adapter-neon',
        '!@prisma/adapter-pg',
        '!@prisma/adapter-planetscale',
        '!@prisma/adapter-ppg',
        '!@prisma/bundled-js-drivers',
        '!@prisma/client',
        '!@prisma/client-common',
        '!@prisma/client-engine-runtime',
        '!@prisma/client-generator-js',
        '!@prisma/client-generator-registry',
        '!@prisma/client-generator-ts',
        '!@prisma/client-runtime-utils',
        '!@prisma/config',
        '!@prisma/credentials-store',
        '!@prisma/debug',
        '!@prisma/dmmf',
        '!@prisma/driver-adapter-utils',
        '!@prisma/engines',
        '!@prisma/fetch-engine',
        '!@prisma/generator',
        '!@prisma/generator-helper',
        '!@prisma/get-dmmf',
        '!@prisma/get-platform',
        '!@prisma/instrumentation',
        '!@prisma/instrumentation-contract',
        '!@prisma/integration-tests',
        '!@prisma/internals',
        '!@prisma/json-protocol',
        '!@prisma/migrate',
        '!@prisma/nextjs-monorepo-workaround-plugin',
        '!@prisma/param-graph',
        '!@prisma/param-graph-builder',
        '!@prisma/query-plan-executor',
        '!@prisma/schema-files-loader',
        '!@prisma/sqlcommenter',
        '!@prisma/sqlcommenter-query-insights',
        '!@prisma/sqlcommenter-query-tags',
        '!@prisma/sqlcommenter-trace-context',
        '!@prisma/ts-builders',
        '!@prisma/type-benchmark-tests',
        '!bundle-size',
        '!prisma',
        '!oxlint-tsgolint',
      ],
      matchUpdateTypes: ['patch'],
    },
    {
      groupName: 'all minor dependencies',
      groupSlug: 'all-minor',
      matchPackageNames: [
        '*',
        // group:recommended -> group:nodeJs
        '!/(?:^|/)node$/',
        // group:nextjsMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupnextjsmonorepo
        // source: https://github.com/vercel/next.js
        '!next',
        '!@next/bundle-analyzer',
        '!@next/codemod',
        '!@next/env',
        '!@next/eslint-plugin-internal',
        '!@next/eslint-plugin-next',
        '!@next/font',
        '!@next/mdx',
        '!@next/playwright',
        '!@next/plugin-storybook',
        '!@next/polyfill-module',
        '!@next/polyfill-nomodule',
        '!@next/react-refresh-utils',
        '!@next/routing',
        '!@next/swc',
        '!@next/third-parties',
        '!create-next-app',
        '!eslint-config-next',
        '!next-rspack',
        '!styled-jsx',
        // group:linters
        '!*/eslint-plugin',
        '!@babel/eslint-parser',
        '!/^@eslint\\//',
        '!/^@eslint-community\\//',
        '!/^@stylistic\\/eslint-plugin/',
        '!@types/eslint',
        '!/^@types\\/eslint__/',
        '!/^@typescript-eslint\\//',
        '!babel-eslint',
        '!/^eslint/',
        '!globals',
        '!eslint-import-resolver-typescript',
        '!typescript-eslint',
        '!oxlint',
        '!eslint-plugin-oxlint',
        // group:definitelyTyped
        '!/^@types\\//',
        // group:recommended -> group:react
        '!/^react/',
        '!/^@types\\/react/',
        '!react-dom',
        '!@types/react-dom',
        '!@types/react-is',
        // group:recommended -> group:remark
        '!remark',
        '!remark-**',
        // group:semantic-releaseMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupsemantic-releasemonorepo
        // source: https://github.com/semantic-release/**
        '!@semantic-release/apm',
        '!@semantic-release/apm-config',
        '!@semantic-release/changelog',
        '!@semantic-release/commit-analyzer',
        '!@semantic-release/condition-codeship',
        '!@semantic-release/condition-nsp',
        '!@semantic-release/condition-run-script',
        '!@semantic-release/condition-travis',
        '!@semantic-release/error',
        '!@semantic-release/exec',
        '!@semantic-release/git',
        '!@semantic-release/github',
        '!@semantic-release/gitlab',
        '!@semantic-release/gitlab-config',
        '!@semantic-release/last-release-git-tag',
        '!@semantic-release/last-release-npm',
        '!@semantic-release/npm',
        '!@semantic-release/release-notes-generator',
        '!@semantic-release/wordpress',
        '!cracks',
        '!env-ci',
        '!issue-parser',
        '!npm-registry-docker',
        '!semantic-release',
        '!semantic-release-cli',
        '!travis-deploy-once',
        '!prettier',
        '!remark-lint',
        '!standard',
        '!codelyzer',
        '!/\\btslint\\b/',
        // group:test and group:recommended -> jestPlusTypes / jestPlusTSJest
        '!@types/chai',
        '!@types/ember-mocha',
        '!@types/ember-qunit',
        '!@types/enzyme',
        '!@types/istanbul',
        '!@types/jest',
        '!@types/mocha',
        '!@types/mock-fs',
        '!@types/proxyquire',
        '!@types/sinon',
        '!@types/supertest',
        '!coveralls',
        '!ember-exam',
        '!ember-mocha',
        '!ember-qunit',
        '!enzyme',
        '!istanbul',
        '!mock-fs',
        '!nock',
        '!nyc',
        '!proxyquire',
        '!supertest',
        '!ts-auto-mock',
        '!ts-jest',
        '!vitest',
        '!/^@jest\\//',
        '!/^@testing-library\\//',
        '!/^@types\\/testing-library__/',
        '!/^@vitest\\//',
        '!/^chai/',
        '!/^jest/',
        '!/^mocha/',
        '!/^qunit/',
        '!/^should/',
        '!/^sinon/',
        // group:prismaMonorepo
        // preset: https://docs.renovatebot.com/presets-group/#groupprismamonorepo
        // source: https://github.com/prisma/prisma
        '!@prisma/adapter-better-sqlite3',
        '!@prisma/adapter-d1',
        '!@prisma/adapter-libsql',
        '!@prisma/adapter-mariadb',
        '!@prisma/adapter-mssql',
        '!@prisma/adapter-neon',
        '!@prisma/adapter-pg',
        '!@prisma/adapter-planetscale',
        '!@prisma/adapter-ppg',
        '!@prisma/bundled-js-drivers',
        '!@prisma/client',
        '!@prisma/client-common',
        '!@prisma/client-engine-runtime',
        '!@prisma/client-generator-js',
        '!@prisma/client-generator-registry',
        '!@prisma/client-generator-ts',
        '!@prisma/client-runtime-utils',
        '!@prisma/config',
        '!@prisma/credentials-store',
        '!@prisma/debug',
        '!@prisma/dmmf',
        '!@prisma/driver-adapter-utils',
        '!@prisma/engines',
        '!@prisma/fetch-engine',
        '!@prisma/generator',
        '!@prisma/generator-helper',
        '!@prisma/get-dmmf',
        '!@prisma/get-platform',
        '!@prisma/instrumentation',
        '!@prisma/instrumentation-contract',
        '!@prisma/integration-tests',
        '!@prisma/internals',
        '!@prisma/json-protocol',
        '!@prisma/migrate',
        '!@prisma/nextjs-monorepo-workaround-plugin',
        '!@prisma/param-graph',
        '!@prisma/param-graph-builder',
        '!@prisma/query-plan-executor',
        '!@prisma/schema-files-loader',
        '!@prisma/sqlcommenter',
        '!@prisma/sqlcommenter-query-insights',
        '!@prisma/sqlcommenter-query-tags',
        '!@prisma/sqlcommenter-trace-context',
        '!@prisma/ts-builders',
        '!@prisma/type-benchmark-tests',
        '!bundle-size',
        '!prisma',
        '!oxlint-tsgolint',
      ],
      matchUpdateTypes: ['minor'],
    },
    {
      description: 'Allow immediate updates for preapproved npm packages',
      matchDatasources: ['npm'],
      matchPackageNames: ['/^@exercode\\//', '/^@willbooster\\//', 'next', '/^@next\\//', 'react', 'react-dom'],
      minimumReleaseAge: '0 days',
    },
    {
      matchDepTypes: ['overrides', 'resolutions'],
      enabled: true,
    },
    {
      groupName: 'willbooster-config',
      matchPackageNames: ['/^@willbooster/.*config/'],
    },
    {
      groupName: 'python',
      matchPackageNames: ['python'],
    },
    {
      ignoreUnstable: false,
      matchPackageNames: ['/yarn/'],
    },
    {
      matchPackageNames: ['node'],
      allowedVersions: '<25',
    },
    {
      matchPackageNames: ['babel-plugin-react-compiler', 'eslint-plugin-react-compiler'],
      ignoreUnstable: false,
    },
    {
      matchPackageNames: ['eslint', '@types/eslint'],
      enabled: false,
    },
    {
      matchPackageNames: ['@blitzjs/auth', '@blitzjs/next', '@blitzjs/rpc', 'blitz'],
      enabled: false,
    },
    {
      description: 'Automatically merge Docker digest updates',
      matchUpdateTypes: ['digest'],
      matchDatasources: ['docker'],
      automerge: true,
      automergeType: 'branch',
      automergeStrategy: 'squash',
    },
    {
      matchPackageNames: ['*', '!zod'],
      rangeStrategy: 'pin',
    },
    {
      matchDepTypes: ['engines', 'peerDependencies'],
      rangeStrategy: 'auto',
    },
    {
      matchPackageNames: ['zod'],
      rangeStrategy: 'replace',
    },
    // Prismaがメモリを食いすぎてRenovateが落ちるので対象外とする。
    {
      matchPackageNames: ['prisma', '@prisma/client'],
      enabled: false,
    },
  ],
  schedule: ['after 5am on Saturday'],
  timezone: 'Asia/Tokyo',
}
