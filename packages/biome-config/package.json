{
  "name": "@willbooster/biome-config",
  "version": "0.0.0-semantically-released",
  "description": "Biome config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/biome-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "main": "biome.jsonc",
  "files": [
    "biome.jsonc"
  ],
  "scripts": {
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true",
    "cleanup": "yarn format",
    "format": "sort-package-json && yarn prettify",
    "prettify": "prettier --cache --color --no-error-on-unmatched-pattern --write \"**/{.*/,}*.{java}\" \"!**/test{-,/}fixtures/**\" || true"
  },
  "prettier": "@willbooster/prettier-config",
  "devDependencies": {
    "@willbooster/prettier-config": "^10.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "sort-package-json": "3.6.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
