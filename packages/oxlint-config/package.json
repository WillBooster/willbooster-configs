{
  "name": "@willbooster/oxlint-config",
  "version": "0.0.0-semantically-released",
  "description": "Oxlint config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/oxlint-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "main": ".oxlintrc.json",
  "files": [
    ".oxlintrc.json"
  ],
  "scripts": {
    "check-all-for-ai": "yarn check-for-ai && yarn test",
    "check-for-ai": "yarn install > /dev/null && yarn format > /dev/null 2> /dev/null || true",
    "cleanup": "yarn format",
    "format": "sort-package-json && yarn prettify",
    "prettify": "prettier --cache --color --write \"**/{.*/,}*.{cjs,css,cts,htm,html,java,js,json,json5,jsonc,jsx,md,mjs,mts,scss,ts,tsx,vue,yaml,yml}\" \"!**/test{-,/}fixtures/**\" || true"
  },
  "prettier": "@willbooster/prettier-config",
  "devDependencies": {
    "@willbooster/prettier-config": "workspace:*",
    "lint-staged": "16.4.0",
    "prettier": "3.8.1",
    "prettier-plugin-java": "2.8.1",
    "sort-package-json": "3.6.1"
  },
  "peerDependencies": {
    "oxlint": ">=1.57.0",
    "oxlint-tsgolint": ">=0.18.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
