{
  "name": "@willbooster/oxfmt-config",
  "version": "0.0.0-semantically-released",
  "description": "Oxfmt config for WillBooster projects",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/willbooster-configs.git",
    "directory": "packages/oxfmt-config"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./config.d.ts",
      "default": "./config.mjs"
    }
  },
  "main": "config.mjs",
  "types": "config.d.ts",
  "files": [
    "config.d.ts",
    "config.mjs",
    "oxfmt.config.ts",
    "config.d.mts"
  ],
  "scripts": {
    "cleanup": "bun wb lint --fix --format",
    "format": "bun wb lint --format",
    "lint": "bun wb lint",
    "lint-fix": "bun wb lint --fix",
    "test": "bun wb test",
    "verify": "bun wb verify",
    "verify-full": "bun wb verify --full"
  },
  "devDependencies": {
    "@willbooster/wb": "15.0.4",
    "sort-package-json": "4.0.0"
  },
  "peerDependencies": {
    "oxfmt": ">=0.42.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
