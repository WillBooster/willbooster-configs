{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [
    "**/.agents/**",
    "**/.claude/**",
    "**/.devcontainer/**",
    "**/.idea/AugmentWebviewStateStore.xml",
    "**/.idea/copilot.*/**",
    "**/.idea/copilot/**",
    "**/.playwright-cli/**",
    "**/.serena/**",
    "**/.tmp/**",
    "**/.venv/**",
    "**/.yarn/**",
    "**/3rd-party/**",
    "**/@types/**",
    "**/@willbooster/**",
    "**/__generated__/**",
    "**/android/**",
    "**/bin/**",
    "**/build/**",
    "**/coverage/**",
    "**/dist/**",
    "**/ios/**",
    "**/no-format/**",
    "**/node_modules/**",
    "**/temp/**",
    "**/tmp/**",
    "**/test-fixtures/**",
    "**/test-results/**",
    "**/test/fixtures/**",
    "**/.aider*",
    "**/.env.production",
    "**/.pnp.js",
    "**/*/mount/*.hash",
    "**/*.d.ts",
    "**/*.min.*js"
  ],
  "printWidth": 120,
  "singleQuote": true,
  "trailingComma": "es5"
}
