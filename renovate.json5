{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  description: 'Default preset for use with WillBooster and WillBoosterLab repos',
  extends: [
    'config:recommended',
    ':automergeDigest',
    ':automergeLinters',
    ':automergeMinor',
    ':automergePr',
    ':automergeTesters',
    ':automergeTypes',
    ':prImmediately',
    ':rebaseStalePrs',
    ':semanticCommits',
    'group:linters',
    'group:nextjsMonorepo',
    'group:nodeJs',
    'group:test',
    'group:definitelyTyped',
    'group:prismaMonorepo',
    'group:recommended',
    'group:typescript-eslintMonorepo',
    'group:semantic-releaseMonorepo',
    'group:oxlintMonorepo',
    'docker:enableMajor',
    'docker:pinDigests',
  ],
  dependencyDashboardAutoclose: true,
  packageRules: [
    {
      matchDatasources: ['npm'],
      minimumReleaseAge: '5 days',
    },
    {
      groupName: 'all patch dependencies',
      groupSlug: 'all-patch',
      matchPackageNames: [
        '*',
        // group:nodeJs
        '!/(?:^|/)node$/',
        // group:nextjsMonorepo
        '!next',
        '!/^@next\\//',
        '!eslint-config-next',
        // group:linters
        '!*/eslint-plugin',
        '!@babel/eslint-parser',
        '!/^@eslint\\//',
        '!/^@eslint-community\\//',
        '!/^@stylistic\\/eslint-plugin/',
        '!@types/eslint',
        '!/^@types\\/eslint__/',
        '!babel-eslint',
        '!/^eslint/',
        '!globals',
        '!eslint-import-resolver-typescript',
        // group:definitelyTyped
        '!/^@types\\//',
        // packages:react
        '!/^react/',
        '!/^@types\\/react/',
        // group:semantic-releaseMonorepo
        '!semantic-release',
        '!/^@semantic-release\\//',
        '!@anolilab/multi-semantic-release',
        '!prettier',
        '!remark-lint',
        '!standard',
        '!codelyzer',
        '!/\\btslint\\b/',
        // group:test
        '!@types/chai',
        '!@types/ember-mocha',
        '!@types/ember-qunit',
        '!@types/enzyme',
        '!@types/istanbul',
        '!@types/jest',
        '!@types/mocha',
        '!@types/mock-fs',
        '!@types/proxyquire',
        '!@types/sinon',
        '!@types/supertest',
        '!coveralls',
        '!ember-exam',
        '!ember-mocha',
        '!ember-qunit',
        '!enzyme',
        '!istanbul',
        '!mock-fs',
        '!nock',
        '!nyc',
        '!proxyquire',
        '!supertest',
        '!ts-auto-mock',
        '!ts-jest',
        '!vitest',
        '!/^@jest\\//',
        '!/^@testing-library\\//',
        '!/^@types\\/testing-library__/',
        '!/^@vitest\\//',
        '!/^chai/',
        '!/^jest/',
        '!/^mocha/',
        '!/^qunit/',
        '!/^should/',
        '!/^sinon/',
        '!oxlint-tsgolint',
      ],
      matchUpdateTypes: ['patch'],
    },
    {
      groupName: 'all minor dependencies',
      groupSlug: 'all-minor',
      matchPackageNames: [
        '*',
        // group:nodeJs
        '!/(?:^|/)node$/',
        // group:nextjsMonorepo
        '!next',
        '!/^@next\\//',
        '!eslint-config-next',
        // group:linters
        '!*/eslint-plugin',
        '!@babel/eslint-parser',
        '!/^@eslint\\//',
        '!/^@eslint-community\\//',
        '!/^@stylistic\\/eslint-plugin/',
        '!@types/eslint',
        '!/^@types\\/eslint__/',
        '!babel-eslint',
        '!/^eslint/',
        '!globals',
        '!eslint-import-resolver-typescript',
        // group:definitelyTyped
        '!/^@types\\//',
        // packages:react
        '!/^react/',
        '!/^@types\\/react/',
        // group:semantic-releaseMonorepo
        '!semantic-release',
        '!/^@semantic-release\\//',
        '!@anolilab/multi-semantic-release',
        '!prettier',
        '!remark-lint',
        '!standard',
        '!codelyzer',
        '!/\\btslint\\b/',
        // group:test
        '!@types/chai',
        '!@types/ember-mocha',
        '!@types/ember-qunit',
        '!@types/enzyme',
        '!@types/istanbul',
        '!@types/jest',
        '!@types/mocha',
        '!@types/mock-fs',
        '!@types/proxyquire',
        '!@types/sinon',
        '!@types/supertest',
        '!coveralls',
        '!ember-exam',
        '!ember-mocha',
        '!ember-qunit',
        '!enzyme',
        '!istanbul',
        '!mock-fs',
        '!nock',
        '!nyc',
        '!proxyquire',
        '!supertest',
        '!ts-auto-mock',
        '!ts-jest',
        '!vitest',
        '!/^@jest\\//',
        '!/^@testing-library\\//',
        '!/^@types\\/testing-library__/',
        '!/^@vitest\\//',
        '!/^chai/',
        '!/^jest/',
        '!/^mocha/',
        '!/^qunit/',
        '!/^should/',
        '!/^sinon/',
        '!oxlint-tsgolint',
      ],
      matchUpdateTypes: ['minor'],
    },
    {
      description: 'Allow immediate updates for preapproved npm packages',
      matchDatasources: ['npm'],
      matchPackageNames: ['/^@exercode\\//', '/^@willbooster\\//', 'next', '/^@next\\//', 'react', 'react-dom'],
      minimumReleaseAge: '0 days',
    },
    {
      matchDepTypes: ['overrides', 'resolutions'],
      enabled: true,
    },
    {
      groupName: 'willbooster-config',
      matchPackageNames: ['/^@willbooster/.*config/'],
    },
    {
      groupName: 'python',
      matchPackageNames: ['python'],
    },
    {
      ignoreUnstable: false,
      matchPackageNames: ['/yarn/'],
    },
    {
      matchPackageNames: ['node'],
      allowedVersions: '<25',
    },
    {
      matchPackageNames: ['babel-plugin-react-compiler', 'eslint-plugin-react-compiler'],
      ignoreUnstable: false,
    },
    {
      matchPackageNames: ['eslint', '@types/eslint'],
      enabled: false,
    },
    {
      matchPackageNames: ['@blitzjs/auth', '@blitzjs/next', '@blitzjs/rpc', 'blitz'],
      enabled: false,
    },
    {
      description: 'Automatically merge Docker digest updates',
      matchUpdateTypes: ['digest'],
      matchDatasources: ['docker'],
      automerge: true,
      automergeType: 'branch',
      automergeStrategy: 'squash',
    },
    {
      matchPackageNames: ['*', '!zod'],
      rangeStrategy: 'pin',
    },
    {
      matchDepTypes: ['engines', 'peerDependencies'],
      rangeStrategy: 'auto',
    },
    {
      matchPackageNames: ['zod'],
      rangeStrategy: 'replace',
    },
    // Prismaがメモリを食いすぎてRenovateが落ちるので対象外とする。
    {
      matchPackageNames: ['prisma', '@prisma/client'],
      enabled: false,
    },
  ],
  schedule: ['after 5am on Saturday'],
  timezone: 'Asia/Tokyo',
}
