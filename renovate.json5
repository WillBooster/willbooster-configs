{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  description: 'Default preset for use with WillBooster and WillBoosterLab repos',
  extends: [
    'config:recommended',
    ':automergeDigest',
    ':automergeLinters',
    ':automergeMinor',
    ':automergePr',
    ':automergeTesters',
    ':automergeTypes',
    ':maintainLockFilesWeekly',
    ':prImmediately',
    ':rebaseStalePrs',
    ':semanticCommits',
    'docker:enableMajor',
    'docker:pinDigests',
  ],
  dependencyDashboardAutoclose: true,
  packageRules: [
    {
      matchDatasources: ['npm', 'pypi'],
      minimumReleaseAge: '5 days',
    },
    {
      groupName: 'all patch dependencies',
      groupSlug: 'all-patch',
      matchPackageNames: ['*'],
      matchUpdateTypes: ['patch'],
    },
    {
      groupName: 'all minor dependencies',
      groupSlug: 'all-minor',
      matchPackageNames: ['*'],
      matchUpdateTypes: ['minor'],
    },
    {
      description: 'Custom replacement for group:nextjsMonorepo',
      groupName: 'nextjs monorepo',
      groupSlug: 'nextjs-monorepo',
      matchSourceUrls: ['https://github.com/vercel/next.js**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 30,
    },
    {
      description: 'Custom replacement for group:linters',
      groupName: 'linters',
      groupSlug: 'linters',
      matchPackageNames: [
        '*/eslint-plugin',
        '@biomejs/**',
        '@babel/eslint-parser',
        '@eslint/**',
        '@eslint-community/**',
        '@stylistic/eslint-plugin**',
        '@types/eslint',
        '@types/eslint__**',
        '@typescript-eslint/**',
        'babel-eslint',
        'eslint**',
        'typescript-eslint',
        'oxlint',
        'eslint-plugin-oxlint',
        'oxlint-**',
        'oxfmt',
        'oxfmt-**',
        'prettier',
        'remark-lint',
        'standard',
        'codelyzer',
        '/\\btslint\\b/',
      ],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 25,
    },
    {
      description: 'Custom replacement for group:definitelyTyped',
      groupName: 'Definitely Typed',
      groupSlug: 'definitely-typed',
      matchPackageNames: ['@types/**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 20,
    },
    {
      description: 'Custom replacement for group:test',
      groupName: 'test packages',
      groupSlug: 'test-packages',
      matchPackageNames: [
        '@types/chai',
        '@types/ember-mocha',
        '@types/ember-qunit',
        '@types/enzyme',
        '@types/istanbul',
        '@types/jest',
        '@types/mocha',
        '@types/mock-fs',
        '@types/proxyquire',
        '@types/sinon',
        '@types/supertest',
        'coveralls',
        'ember-exam',
        'ember-mocha',
        'ember-qunit',
        'enzyme',
        'istanbul',
        'mock-fs',
        'nock',
        'nyc',
        'proxyquire',
        'supertest',
        'ts-auto-mock',
        'ts-jest',
        'vitest',
        '@jest/**',
        '@testing-library/**',
        '@types/testing-library__**',
        '@vitest/**',
        'chai**',
        'jest**',
        'mocha**',
        'qunit**',
        'should**',
        'sinon**',
      ],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 15,
    },
    {
      description: 'Custom replacement for the nodeJs part of group:recommended',
      groupName: 'nodejs',
      groupSlug: 'nodejs',
      matchPackageNames: ['/(?:^|/)node$/'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 12,
    },
    {
      description: 'Custom replacement for the react part of group:recommended',
      groupName: 'react',
      groupSlug: 'react',
      matchDatasources: ['npm'],
      matchPackageNames: ['@types/react**', 'react**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 12,
    },
    {
      description: 'Custom replacement for the remark part of group:recommended',
      groupName: 'remark',
      groupSlug: 'remark',
      matchPackageNames: ['remark', 'remark-**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 10,
    },
    {
      description: 'Custom replacement for group:semantic-releaseMonorepo',
      groupName: 'semantic-release monorepo',
      groupSlug: 'semantic-release-monorepo',
      matchSourceUrls: ['https://github.com/semantic-release/**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 10,
    },
    {
      description: 'Custom replacement for group:prismaMonorepo',
      groupName: 'prisma monorepo',
      groupSlug: 'prisma-monorepo',
      matchSourceUrls: ['https://github.com/prisma/prisma**'],
      matchUpdateTypes: ['major', 'minor', 'patch'],
      prPriority: 5,
    },
    {
      description: 'Allow immediate updates for preapproved npm packages',
      matchDatasources: ['npm'],
      matchPackageNames: [
        '/^@exercode\\//',
        '/^@willbooster\\//',
        'agent-runtime-kit',
        'next',
        '/^@next\\//',
        'react',
        'react-dom',
      ],
      minimumReleaseAge: '0 days',
    },
    {
      matchDepTypes: ['overrides', 'resolutions'],
      enabled: true,
    },
    {
      groupName: 'willbooster-config',
      matchPackageNames: ['/^@willbooster/.*config/'],
    },
    {
      groupName: 'python',
      matchPackageNames: ['python'],
    },
    {
      ignoreUnstable: false,
      matchPackageNames: ['/yarn/'],
    },
    {
      matchPackageNames: ['node'],
      allowedVersions: '<25',
    },
    {
      matchPackageNames: ['babel-plugin-react-compiler', 'eslint-plugin-react-compiler'],
      ignoreUnstable: false,
    },
    {
      description: 'Ignore Drizzle commit-suffixed prereleases that SemVer can sort after beta releases',
      matchDatasources: ['npm'],
      matchPackageNames: ['drizzle-kit', 'drizzle-orm'],
      allowedVersions: '/^\\d+\\.\\d+\\.\\d+(?:-[a-z]+\\.\\d+)?$/',
    },
    {
      matchPackageNames: ['eslint', '@types/eslint'],
      enabled: false,
    },
    {
      matchPackageNames: ['@blitzjs/auth', '@blitzjs/next', '@blitzjs/rpc', 'blitz'],
      enabled: false,
    },
    {
      description: 'Automatically merge Docker digest updates',
      matchUpdateTypes: ['digest'],
      matchDatasources: ['docker'],
      automerge: true,
      automergeType: 'branch',
      automergeStrategy: 'squash',
    },
    {
      matchPackageNames: ['*', '!zod'],
      rangeStrategy: 'pin',
    },
    {
      matchDepTypes: ['engines', 'peerDependencies'],
      rangeStrategy: 'auto',
    },
    {
      matchPackageNames: ['zod'],
      rangeStrategy: 'replace',
    },
    // Prismaがメモリを食いすぎてRenovateが落ちるので対象外とする。
    {
      matchPackageNames: ['prisma', '@prisma/client'],
      enabled: false,
    },
  ],
  schedule: ['after 5am on Saturday'],
  timezone: 'Asia/Tokyo',
}
